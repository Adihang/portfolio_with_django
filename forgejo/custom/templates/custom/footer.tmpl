{{/* ── Hanplanet HP Footer ──────────────────────────────────── */}}
<footer class="site-footer-links" aria-label="Legal links">
  <a class="site-footer-link" href="https://www.hanplanet.com/ko/privacy">Privacy Policy</a>
  <span class="site-footer-sep">/</span>
  <a class="site-footer-link" href="https://www.hanplanet.com/ko/terms">Terms of Service</a>
</footer>

{{/* 공통 JS — www.hanplanet.com과 동일한 순서 */}}
<script src="/assets/js/popup_common.js"></script>
<script src="/assets/js/bootstrap.min.js"></script>
<script src="/assets/js/site_nav_responsive_manager.js"></script>
<script src="/assets/js/script.js"></script>

<script>
(function () {
  /* ── body.page + body.theme-dark — www base.html 공통 클래스 ── */
  document.body.classList.add('page');
  document.body.classList.add('theme-preinit');
  document.body.dataset.authenticated = '{{if .IsSigned}}1{{else}}0{{end}}';
  (function () {
    try {
      var stored = window.localStorage.getItem('portfolio_theme_mode');
      var prefersDark;
      if (stored === 'dark') {
        prefersDark = true;
      } else if (stored === 'light') {
        prefersDark = false;
      } else {
        prefersDark = Boolean(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
      }
      document.body.classList.toggle('theme-dark', prefersDark);
    } catch (e) {}
  })();

  /* ── Hanplanet SSO 복귀 ─────────────────────────────────── */
  var match = document.cookie.match(/(?:^|;\s*)hp_sso_return=([^;]+)/);
  if (match) {
    var returnUrl = decodeURIComponent(match[1]);
    document.cookie = 'hp_sso_return=; expires=Thu, 01 Jan 1970 00:00:00 UTC; domain=.hanplanet.com; path=/; secure; samesite=lax';
    if (/^\//.test(returnUrl) || /^https?:\/\/(www\.)?hanplanet\.com(\/|$)/.test(returnUrl)) {
      window.location.replace(returnUrl);
      return;
    }
  }

  /* ── 로그인 페이지 → Hanplanet SSO 자동 리다이렉트 ─────── */
  (function redirectLoginToSSO() {
    var path = window.location.pathname;
    if (path === '/user/login' || path === '/user/login/') {
      var params = new URLSearchParams(window.location.search);
      var redirectTo = params.get('redirect_to') || '';
      var target = '/user/oauth2/hanplanet';
      if (redirectTo) target += '?redirect_to=' + encodeURIComponent(redirectTo);
      window.location.replace(target);
    }
  })();

  /* ── 현재 페이지 네비 링크 active 표시 ──────────────────── */
  (function markActiveNavLink() {
    var curPath = window.location.pathname;
    var curHost = window.location.hostname;
    document.querySelectorAll('.ui-nav-link').forEach(function (link) {
      var href = link.getAttribute('href');
      if (!href || href === '#') return;
      try {
        var url = new URL(href, window.location.origin);
        if (url.hostname === curHost && curPath.startsWith(url.pathname) && url.pathname !== '/') {
          link.classList.add('ui-active');
        }
      } catch (e) {}
    });
  })();

  /* ── 반응형 네비바 ── */
  if (typeof window.__initSiteNavResponsiveManager === 'function') {
    window.__initSiteNavResponsiveManager();
  }
})();
</script>
