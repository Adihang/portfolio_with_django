{{/* Hanplanet custom theme */}}
{{/* FOUC 방지 — CSS 로드 전 배경색 즉시 적용 (www base.html 동일 패턴) */}}
<style data-surface-light="base-preload">
  html.preload-light-bg,
  html.preload-light-bg body {
    background: #ffffff;
    background-image: none;
  }
  html.preload-dark-bg,
  html.preload-dark-bg body {
    background: #222222;
    background-image: none;
  }
  body.theme-preinit,
  body.theme-preinit * {
    transition: none;
    animation: none;
  }
</style>
<script>
(function () {
  try {
    var cookieMatch = document.cookie.match(/(?:^|;\s*)portfolio_theme_mode=([^;]+)/);
    var stored = (cookieMatch ? decodeURIComponent(cookieMatch[1]) : null) || window.localStorage.getItem('portfolio_theme_mode');
    var prefersDark;
    if (stored === 'dark') {
      prefersDark = true;
    } else if (stored === 'light') {
      prefersDark = false;
    } else {
      prefersDark = Boolean(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
    }
    document.documentElement.classList.add(prefersDark ? 'preload-dark-bg' : 'preload-light-bg');
  } catch (e) {
    document.documentElement.classList.add('preload-light-bg');
  }
})();
</script>
